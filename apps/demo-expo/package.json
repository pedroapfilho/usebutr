{
  "name": "demo-expo",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "portless run --https demo-expo.butr -- expo start --web",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export --platform web",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .expo node_modules dist"
  },
  "dependencies": {
    "@expo/metro-runtime": "^55.0.11",
    "butr": "workspace:*",
    "expo": "^55.0.23",
    "expo-constants": "^55.0.16",
    "expo-linking": "^55.0.15",
    "expo-router": "^55.0.14",
    "expo-status-bar": "^55.0.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-native": "^0.85.3",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-screens": "^4.0.0",
    "react-native-web": "^0.19.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@repo/typescript-config": "workspace:*",
    "@types/react": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
