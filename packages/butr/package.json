{
  "name": "butr",
  "version": "0.1.0",
  "description": "Multi-chain wallet management primitives for React. Headless, ~10 kB gzipped, bring your own connectors.",
  "keywords": [
    "ethereum",
    "evm",
    "headless",
    "multichain",
    "react",
    "react-hooks",
    "react-native",
    "solana",
    "typescript",
    "wallet",
    "web3",
    "zustand"
  ],
  "homepage": "https://github.com/pedroapfilho/butr#readme",
  "bugs": {
    "url": "https://github.com/pedroapfilho/butr/issues"
  },
  "license": "MIT",
  "author": "Pedro Filho <pedro@filho.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedroapfilho/butr.git",
    "directory": "packages/butr"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auto": {
      "types": "./dist/auto/index.d.ts",
      "default": "./dist/auto/index.js"
    },
    "./ledger": {
      "types": "./dist/ledger/index.d.ts",
      "default": "./dist/ledger/index.js"
    },
    "./walletconnect": {
      "types": "./dist/walletconnect/index.d.ts",
      "default": "./dist/walletconnect/index.js"
    }
  },
  "scripts": {
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "lint": "oxlint src",
    "prepack": "pnpm run build",
    "prepare": "pnpm run build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@butr/core": "workspace:*",
    "@butr/evm": "workspace:*",
    "@butr/react": "workspace:*"
  },
  "devDependencies": {
    "@ledgerhq/hw-app-eth": "^7.8.2",
    "@ledgerhq/hw-transport-webusb": "^6.34.2",
    "@repo/typescript-config": "workspace:*",
    "@types/react": "^19.0.0",
    "@wallet-standard/app": "^1.1.0",
    "@walletconnect/universal-provider": "^2.23.9",
    "react": "^19.2.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "zustand": "^5.0.0"
  },
  "peerDependencies": {
    "@ledgerhq/hw-app-eth": ">=6.0.0 <8.0.0",
    "@ledgerhq/hw-transport-webusb": ">=6.0.0",
    "@wallet-standard/app": "^1.1.0",
    "@walletconnect/universal-provider": "^2.0.0",
    "react": ">=18.0.0",
    "zustand": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@ledgerhq/hw-app-eth": {
      "optional": true
    },
    "@ledgerhq/hw-transport-webusb": {
      "optional": true
    },
    "@wallet-standard/app": {
      "optional": true
    },
    "@walletconnect/universal-provider": {
      "optional": true
    }
  }
}
