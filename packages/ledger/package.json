{
  "name": "@usebutr/ledger",
  "version": "0.2.5",
  "description": "Ledger hardware-wallet adapter for butr (EVM + SVM + Sui + Bitcoin).",
  "license": "MIT",
  "author": "Pedro Filho <pedro@filho.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pedroapfilho/usebutr.git",
    "directory": "packages/ledger"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "tsdown --watch",
    "lint": "oxlint src",
    "prepack": "pnpm run build",
    "prepare": "pnpm run build",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@usebutr/core": "workspace:*"
  },
  "devDependencies": {
    "@ledgerhq/hw-app-btc": "^11.2.1",
    "@ledgerhq/hw-app-eth": "^7.8.8",
    "@ledgerhq/hw-app-solana": "^7.10.5",
    "@ledgerhq/hw-app-sui": "^1.11.3",
    "@ledgerhq/hw-transport-webusb": "^6.35.0",
    "@repo/config-vitest": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@ledgerhq/hw-app-btc": ">=10.0.0 <12.0.0",
    "@ledgerhq/hw-app-eth": ">=6.0.0 <8.0.0",
    "@ledgerhq/hw-app-solana": ">=7.0.0 <8.0.0",
    "@ledgerhq/hw-app-sui": ">=1.0.0 <2.0.0",
    "@ledgerhq/hw-transport-webusb": ">=6.0.0"
  }
}
